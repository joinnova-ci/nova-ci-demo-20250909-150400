```bash
# Clone and install in development mode
git clone https://github.com/nova-solve/ci-auto-rescue.git
cd ci-auto-rescue
pip install -e ".[dev]"

# Run tests
pytest tests/ -v

# Run linting
ruff check src/
mypy src/
```

